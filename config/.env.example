# Library Assessment Assistant configuration

# Data storage
DATABASE_PATH=data/library.db
CHROMA_DB_PATH=data/chroma_db

# Local RAG / LLM runtime
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_LOCAL_FILES_ONLY=true
LLM_GENERATION_TIMEOUT_SECONDS=90

# Query behavior
CONTEXT_WINDOW_SIZE=5
TOP_K_RETRIEVAL=5
MAX_CONTEXT_TOKENS=4000

# Qualitative analysis
DEFAULT_N_THEMES=5
MIN_RESPONSES_FOR_ANALYSIS=10
ENABLE_ENHANCED_SENTIMENT=false

# Authentication
SESSION_TIMEOUT_MINUTES=60
MAX_LOGIN_ATTEMPTS=5
ENABLE_DEMO_LOGIN=false
DEMO_USERNAME=demo_user

# Logging and governance
LOG_LEVEL=INFO
ENABLE_AUDIT_LOGGING=true
ENABLE_DATA_PROVENANCE=true
